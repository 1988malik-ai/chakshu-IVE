{
  "name": "chakshu-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "description": "Chakshu Forensics — Windows desktop shell",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.chakshu.forensics",
    "productName": "Chakshu Forensics",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../dist-backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "../frontend/public/favicon.svg",
      "artifactName": "Chakshu-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "Chakshu-Native-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Chakshu Forensics"
    }
  }
}
